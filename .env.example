# CognitiveDoc AI - IBM Cloud Configuration (Lite Tiers)
PORT=3000

# ----------------- IBM Watson Discovery -----------------
# Get these from your Watson Discovery (Lite) service instance dashboard
WATSON_DISCOVERY_APIKEY=
WATSON_DISCOVERY_URL=
WATSON_DISCOVERY_PROJECT_ID=

# ----------------- IBM watsonx.ai -----------------
# Get these from your IBM Cloud IAM API Keys and watsonx.ai project settings
WATSONX_AI_APIKEY=
WATSONX_AI_SERVICE_URL=https://us-south.ml.cloud.ibm.com
WATSONX_AI_PROJECT_ID=
# Granite models are free/lite tier friendly (e.g., ibm/granite-13b-chat-v2 or ibm/granite-3-8b-instruct)
WATSONX_AI_MODEL_ID=ibm/granite-3-8b-instruct
